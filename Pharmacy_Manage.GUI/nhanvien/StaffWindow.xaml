<Window x:Class="Pharmacy_Manage.GUI.StaffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pharmacy_Manage.GUI"
        mc:Ignorable="d"
        Title="Nhân Viên Bán Hàng - Clinic Track" Height="768" Width="1366"
        WindowStartupLocation="CenterScreen" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <Style x:Key="SidebarBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#F7FAFC" CornerRadius="25" BorderBrush="#E2E8F0" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1E293B" CornerRadius="25,0,0,25">
                <Grid>
                    <StackPanel Margin="0,50,0,0">

                        <TextBlock FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,50">
                            <Run Text="Clinic" Foreground="White" />
                            <Run Text="Track" Foreground="#4FD1C5" />
                        </TextBlock>

                        <Button x:Name="BtnLichhen" Style="{StaticResource SidebarBtnStyle}" Tag="0" Click="Menu_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📅" FontSize="18" Margin="0,0,15,0"/>
                                <TextBlock Text="Tiếp nhận bệnh nhân"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnBanthuoc" Style="{StaticResource SidebarBtnStyle}" Tag="1" Click="Menu_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🛒" FontSize="18" Margin="0,0,15,0"/>
                                <TextBlock Text="Bán thuốc"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnQLthuoc" Style="{StaticResource SidebarBtnStyle}" Tag="2" Click="Menu_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💊" FontSize="18" Margin="0,0,15,0"/>
                                <TextBlock Text="Tra cứu kho thuốc"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnQLkhachhang" Style="{StaticResource SidebarBtnStyle}" Tag="3" Click="Menu_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👥" FontSize="18" Margin="0,0,15,0"/>
                                <TextBlock Text="Khách hàng"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Button Style="{StaticResource SidebarBtnStyle}" VerticalAlignment="Bottom" Margin="10,0,10,40" Click="Logout_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚪" FontSize="18" Margin="0,0,15,0"/>
                            <TextBlock Text="Đăng xuất" Foreground="#F87171"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="20,0,20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🕒" FontSize="18" Foreground="#718096" Margin="0,0,10,0"/>
                        <TextBlock x:Name="txtClock" Text="00:00 - DD/MM/YYYY" FontSize="15" FontWeight="SemiBold" Foreground="#4A5568"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border x:Name="ProfileBorder" Background="White" CornerRadius="25" Height="45" Padding="5,0,15,0" Margin="0,0,20,0" 
                                Cursor="Hand" MouseLeftButtonDown="ProfileBorder_MouseLeftButtonDown">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="35" Height="35" Margin="5,0,10,0" Fill="#2C9BB3"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="txtStaffName" Text="Tên Nhân Viên" FontWeight="Bold" Foreground="#2D3748"/>
                                    <TextBlock x:Name="txtStaffRole" Text="Staff / Ca Sáng" FontSize="12" Foreground="#718096"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Popup x:Name="ProfilePopup" PlacementTarget="{Binding ElementName=ProfileBorder}" Placement="Bottom" StaysOpen="True" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="10">
                            <Border Background="White" CornerRadius="12" Padding="20" Width="260" BorderBrush="#E2E8F0" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" Opacity="0.15" ShadowDepth="4"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Grid Margin="0,0,0,15">
                                        <TextBlock Text="👤 Thông tin tài khoản" FontWeight="Bold" FontSize="16" Foreground="#2D3748" VerticalAlignment="Center"/>
                                        <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Foreground="#A0AEC0" FontSize="14" FontWeight="Bold" Cursor="Hand" Click="BtnClosePopup_Click" ToolTip="Đóng"/>
                                    </Grid>

                                    <TextBlock Text="Họ và tên:" Foreground="#718096" FontSize="12" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="popFullName" Text="Đang tải..." FontWeight="SemiBold" FontSize="14" Foreground="#2D3748" Margin="0,0,0,10"/>

                                    <TextBlock Text="Tên đăng nhập (Email):" Foreground="#718096" FontSize="12" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="popUsername" Text="Đang tải..." FontWeight="SemiBold" FontSize="14" Foreground="#2D3748" Margin="0,0,0,10"/>

                                    <TextBlock Text="Quyền hạn:" Foreground="#718096" FontSize="12" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="popRole" Text="Đang tải..." FontWeight="SemiBold" FontSize="14" Foreground="#2C9BB3" Margin="0,0,0,5"/>
                                </StackPanel>
                            </Border>
                        </Popup>

                        <Button Content="_" Width="30" Height="30" Background="Transparent" BorderThickness="0" FontSize="16" FontWeight="Bold" Foreground="#718096" Cursor="Hand" Click="Minimize_Click"/>
                        <Button Content="✕" Width="30" Height="30" Background="Transparent" BorderThickness="0" FontSize="14" FontWeight="Bold" Foreground="#E74C3C" Cursor="Hand" Click="Close_Click"/>
                    </StackPanel>
                </Grid>

                <TabControl x:Name="MainTabControl" Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0,10,0,0">
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </Style>
                    </TabControl.ItemContainerStyle>

                    <TabItem>
                        <local:DatLich_view/>
                    </TabItem>

                    <TabItem>
                        <local:Banthuocview/>
                    </TabItem>

                    <TabItem>
                        <local:QLthuoc_view/>
                    </TabItem>

                    <TabItem>
                        <local:QLkhachhang_view/>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </Border>
</Window>