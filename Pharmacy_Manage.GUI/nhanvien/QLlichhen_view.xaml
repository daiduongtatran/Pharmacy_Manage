<UserControl x:Class="Pharmacy_Manage.GUI.QLlichhen_view"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Pharmacy_Manage.GUI"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1000">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Buttons bar -->
            <RowDefinition Height="*"/>    <!-- Main content -->
        </Grid.RowDefinitions>

        <!-- Top buttons -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,12"/>

        <!-- Main layout: left = form, right = lists -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <!-- form -->
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <!-- lists -->
            </Grid.ColumnDefinitions>

            <!-- Left: Receive booking form -->
            <Border Grid.Column="0" Background="#FAFBFC" BorderBrush="#E6EEF5" BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel>
                    <TextBlock Text="Tiếp nhận đặt lịch" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Mã bệnh nhân:" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox x:Name="txtPatientId" Grid.Column="1" Height="28" Margin="6,2"/>

                        <TextBlock Grid.Column="0" Grid.Row="1" Text="Tên bệnh nhân:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBox x:Name="txtPatientName" Grid.Column="1" Grid.Row="1" Height="28" Margin="6,10,0,0"/>

                        <TextBlock Grid.Column="0" Grid.Row="2" Text="Ngày:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <DatePicker x:Name="dpAppointmentDate" Grid.Column="1" Grid.Row="2" Height="28" Margin="6,10,0,0"/>

                        <TextBlock Grid.Column="0" Grid.Row="3" Text="Giờ:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBox x:Name="txtAppointmentTime" Grid.Column="1" Grid.Row="3" Height="28" Margin="6,10,0,0" ToolTip="HH:mm"/>

                        <TextBlock Grid.Column="0" Grid.Row="4" Text="Lý do:" VerticalAlignment="Top" Margin="0,10,0,0"/>
                        <TextBox x:Name="txtReason" Grid.Column="1" Grid.Row="4" Margin="6,10,0,0" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"/>

                        <!-- define rows -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button x:Name="btnClearForm" Content="Xóa" Width="90" Margin="6,0" Click="BtnClearForm_Click"/>
                        <Button x:Name="btnSubmitBooking" Content="Lưu đặt lịch" Width="120" Margin="6,0" Click="BtnSubmitBooking_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Right: Appointments + Patient search -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- search patients -->
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                    <!-- appointments list -->
                </Grid.RowDefinitions>

                <!-- Patient search area -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right">
                    <TextBox x:Name="txtSearchPatient" Width="220" Height="30" Margin="0,0,6,0" Text="Tìm theo tên hoặc mã"/>
                    <Button x:Name="btnExecuteSearch" Content="Tìm" Width="80" Height="30" Click="BtnExecuteSearch_Click"/>
                </StackPanel>

                <!-- Appointments DataGrid -->
                <Border Grid.Row="2" Background="White" BorderBrush="#E6EEF5" BorderThickness="1" CornerRadius="8" Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Danh sách lịch hẹn" FontSize="16" FontWeight="Bold" Margin="4"/>
                        <DataGrid x:Name="dgAppointments" Grid.Row="1" Margin="0,8,0,0" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding AppointmentId}" Width="60"/>
                                <DataGridTextColumn Header="Mã BN" Binding="{Binding PatientId}" Width="90"/>
                                <DataGridTextColumn Header="Tên bệnh nhân" Binding="{Binding PatientName}" Width="200"/>
                                <DataGridTextColumn Header="Ngày" Binding="{Binding Date, StringFormat=d}" Width="110"/>
                                <DataGridTextColumn Header="Giờ" Binding="{Binding Time}" Width="80"/>
                                <DataGridTextColumn Header="Lý do" Binding="{Binding Reason}" Width="*"/>
                                <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
