<Window x:Class="Pharmacy_Manage.GUI.nhanvien.ChonDichVuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chọn Dịch Vụ" Height="450" Width="450" 
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="#F5F7F8">

    <Window.Resources>
        <DropShadowEffect x:Key="SoftShadow" Color="Black" BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2C9BB3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C9BB3" Padding="20,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📋" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Text="DANH MỤC DỊCH VỤ" 
                               FontSize="14" FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock Text="Vui lòng chọn các dịch vụ khám cho bệnh nhân" 
                               FontSize="11" Foreground="#E0F2F1" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="15,10,15,0">
            <ItemsControl x:Name="icDichVu">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" 
                                CornerRadius="10" 
                                Margin="0,4" 
                                Padding="12,10"
                                Effect="{StaticResource SoftShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="35"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" 
                                          VerticalAlignment="Center"
                                          Cursor="Hand"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding TenDichVu}"
                                           FontSize="13"
                                           Foreground="#263238"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="5,0"/>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding Gia, StringFormat={}{0:N0} đ}"
                                           FontSize="13"
                                           Foreground="#2C9BB3"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" Padding="15" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Hủy bỏ" 
                        Width="90" Height="35" 
                        Margin="0,0,10,0"
                        Click="BtnBo_Click"
                        Background="Transparent"
                        Foreground="#78909C"
                        FontSize="13"
                        BorderBrush="Transparent"/>

                <Button Content="Hoàn tất" 
                        Style="{StaticResource PrimaryButton}"
                        Width="120" Height="38"
                        Click="BtnHoanTat_Click">
                    <Button.Effect>
                        <DropShadowEffect Color="#2C9BB3" BlurRadius="10" ShadowDepth="1" Opacity="0.2"/>
                    </Button.Effect>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>