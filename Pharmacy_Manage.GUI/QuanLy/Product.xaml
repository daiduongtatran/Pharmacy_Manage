<UserControl x:Class="Pharmacy_Manage.QuanLy.Product"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1000">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Thanh công cụ -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Quản lý kho thuốc" FontSize="28" FontWeight="Bold" Foreground="#2D3748" VerticalAlignment="Center"/>
            <Button Content="+ Thêm mới" Click="BtnAdd_Click" Background="#48BB78" Foreground="White" Padding="20,10" Margin="30,0,0,0" FontWeight="Bold" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="✏️ Sửa" Click="BtnUpdate_Click" Background="#4299E1" Foreground="White" Padding="20,10" Margin="10,0,0,0" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="🗑️ Xóa" Click="BtnDelete_Click" Background="#F56565" Foreground="White" Padding="20,10" Margin="10,0,0,0" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <!-- Bảng dữ liệu -->
        <Border Grid.Row="1" Background="White" CornerRadius="20" Padding="15" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="dgSanPham" AutoGenerateColumns="False" CanUserAddRows="False" 
                      IsReadOnly="True" Background="White" BorderThickness="0" RowHeight="50">
                <DataGrid.Columns>
                    <!-- 1. Các cột cơ bản đầu bảng -->
                    <DataGridTextColumn Header="Mã" Binding="{Binding MaSP}" Width="60"/>
                    <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding TenSP}" Width="130"/>
                    <DataGridTextColumn Header="Loại" Binding="{Binding LoaiSP}" Width="120"/>

                    <!-- 2. HAI CỘT THÊM MỚI Ở GIỮA -->
                    <DataGridTextColumn Header="Giá nhập" 
                        Binding="{Binding GiaNhap, StringFormat='#,##0 đ'}" 
                        Width="110" Foreground="#2D3748"/>

                    <DataGridTextColumn Header="Tồn kho" 
                        Binding="{Binding TonKho}" 
                        Width="80" FontWeight="Bold"/>

                    <!-- 3. Các cột còn lại -->
                    <DataGridTextColumn Header="Giá bán" 
                        Binding="{Binding GiaBan, StringFormat='#,##0 đ'}" 
                        Width="120" Foreground="#3182CE"/>

                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="120"/>

                    <DataGridTextColumn Header="Ghi chú" Binding="{Binding GhiChu}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>