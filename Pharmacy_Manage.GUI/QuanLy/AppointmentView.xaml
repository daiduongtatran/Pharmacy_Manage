<UserControl x:Class="Pharmacy_Manage.QuanLy.AppointmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000" Background="Transparent">

    <UserControl.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#EDF2F7"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,12"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
        </Style>

        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding TrangThai}" Value="Đang chờ">
                    <Setter Property="Background" Value="#FEFCBF"/> </DataTrigger>
                <DataTrigger Binding="{Binding TrangThai}" Value="Đang khám">
                    <Setter Property="Background" Value="#BEE3F8"/> </DataTrigger>
                <DataTrigger Binding="{Binding TrangThai}" Value="Hoàn thành">
                    <Setter Property="Background" Value="#C6F6D5"/> </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding TrangThai}" Value="Đang chờ">
                    <Setter Property="Foreground" Value="#D69E2E"/> </DataTrigger>
                <DataTrigger Binding="{Binding TrangThai}" Value="Đang khám">
                    <Setter Property="Foreground" Value="#2B6CB0"/> </DataTrigger>
                <DataTrigger Binding="{Binding TrangThai}" Value="Hoàn thành">
                    <Setter Property="Foreground" Value="#38A169"/> </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Background="White" CornerRadius="15" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.05" ShadowDepth="2"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="📅 Quản lý Lịch hẹn" FontSize="22" FontWeight="Bold" Foreground="#2D3748"/>
                        <TextBlock Text="Danh sách khách hàng đã đăng ký khám bệnh online" Foreground="#718096" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1" Background="#F7FAFC" CornerRadius="8" BorderThickness="1" BorderBrush="#E2E8F0" Padding="10,0" Width="300" Height="40">
                        <Grid>
                            <TextBlock Text="🔍 Tìm tên hoặc SĐT..." Foreground="#A0AEC0" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Hidden"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox x:Name="txtSearch" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" TextChanged="TxtSearch_TextChanged"/>
                        </Grid>
                    </Border>
                </Grid>

                <DataGrid x:Name="dgLichHen" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" 
                          Background="White" BorderThickness="1" BorderBrush="#E2E8F0" RowHeight="50" 
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EDF2F7">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã LH" Binding="{Binding MaLichHen}" Width="60"/>
                        
                        <DataGridTextColumn Header="Tên Khách Hàng" Binding="{Binding HoTen}" Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Số Điện Thoại" Binding="{Binding SoDienThoai}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#3182CE"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Thời Gian Khám" Binding="{Binding ThoiGianKham, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                        <DataGridTextColumn Header="Chuyên Khoa" Binding="{Binding ChuyenKhoa}" Width="150"/>
                        <DataGridTextColumn Header="Lý Do" Binding="{Binding LyDoKham}" Width="*"/>

                        <DataGridTemplateColumn Header="Trạng Thái" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource StatusBadgeStyle}">
                                        <TextBlock Text="{Binding TrangThai}" Style="{StaticResource StatusTextStyle}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Thao tác" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Xử lý" Background="#38A169" Foreground="White" FontWeight="Bold" 
                                            BorderThickness="0" Padding="10,5" Cursor="Hand" Click="BtnXuLy_Click">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="6"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>