<UserControl x:Class="Pharmacy_Manage.QuanLy.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             Background="Transparent">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFF5F5" CornerRadius="15" Padding="20" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Thuốc sắp hết hàng" Foreground="#C53030" FontSize="16" FontWeight="SemiBold"/>
                    
                    <TextBlock x:Name="txtLowStock" Text="0" FontSize="32" FontWeight="Bold" Foreground="#E53E3E" Margin="0,10"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#FFF5F5" CornerRadius="15" Padding="20" Margin="10,0,10,0">
                <StackPanel>
                    <TextBlock Text="Thuốc sắp/đã hết hạn" Foreground="#C53030" FontSize="16" FontWeight="SemiBold"/>
                   
                    <TextBlock x:Name="txtExpired" Text="0" FontSize="32" FontWeight="Bold" Foreground="#E53E3E" Margin="0,10"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#E6FFFA" CornerRadius="15" Padding="20" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="Doanh thu hôm nay" Foreground="#2C7A7B" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtRevenue" Text="0 đ" FontSize="32" FontWeight="Bold" Foreground="#319795" Margin="0,10"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="White" CornerRadius="15" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="DOANH THU 7 NGÀY GẦN NHẤT" FontWeight="Bold" Foreground="#4A5568" Margin="0,0,0,15"/>

                <lvc:CartesianChart Grid.Row="1" Series="{Binding RevenueSeries}">
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Labels="{Binding ChartLabels}"/>
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis LabelFormatter="{Binding Formatter}" MinValue="0"/>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </Grid>
        </Border>
    </Grid>
</UserControl>