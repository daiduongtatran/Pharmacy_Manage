<UserControl x:Class="Pharmacy_Manage.GUI.QuanLy.Report"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="#F0F2F5">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

        <Grid Margin="20,10,20,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="BÁO CÁO TỔNG QUAN" FontSize="26" FontWeight="Bold" Margin="10,0,0,20" Foreground="#2C3E50"/>

            <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,15">
                <Border Background="White" CornerRadius="12" Margin="10" Padding="25,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Color="#D0D0D0" ShadowDepth="3" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Số lượng đơn hàng" FontSize="14" Foreground="#7F8C8D" FontWeight="Medium"/>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock Text="📦" FontSize="28" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtSoLuongDon" Text="0" FontSize="36" FontWeight="Bold" Foreground="#2196F3" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Margin="10" Padding="25,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Color="#D0D0D0" ShadowDepth="3" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Doanh thu" FontSize="14" Foreground="#7F8C8D" FontWeight="Medium"/>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock Text="💰" FontSize="28" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtDoanhThu" Text="0đ" FontSize="36" FontWeight="Bold" Foreground="#2ECC71" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Margin="10" Padding="25,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Color="#D0D0D0" ShadowDepth="3" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Lợi nhuận" FontSize="14" Foreground="#7F8C8D" FontWeight="Medium"/>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock Text="📈" FontSize="28" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtLoiNhuan" Text="0đ" FontSize="36" FontWeight="Bold" Foreground="#E67E22" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <GroupBox Header="Danh sách hóa đơn gần đây" Grid.Row="2" Margin="10" 
                      FontSize="16" FontWeight="SemiBold" Foreground="#333" Background="White">

                <DataGrid x:Name="dgHoaDon" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False" 
                          Background="Transparent"
                          BorderThickness="0"
                          RowHeight="42"
                          FontSize="14"
                          IsReadOnly="True"
                          SelectionUnit="FullRow"
                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                          MouseDoubleClick="dgHoaDon_MouseDoubleClick">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9FA"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã Hóa Đơn" Binding="{Binding MaHD}" Width="150"/>
                        <DataGridTextColumn Header="Tên Khách Hàng" Binding="{Binding HoTen}" Width="2*"/>
                        <DataGridTextColumn Header="Ngày Lập" Binding="{Binding NgayLap, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Width="180"/>
                        <DataGridTextColumn Header="Tổng Tiền" Binding="{Binding TongThanhToan, StringFormat=\{0:N0\}đ}" Width="1*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,15,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

    </ScrollViewer>
</UserControl>