<Window x:Class="Pharmacy_Manage.GUI.QuanLy.InvoiceDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chi Tiết Hóa Đơn" Height="450" Width="500" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="CHI TIẾT HÓA ĐƠN" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <GroupBox Header="Thông tin khách hàng" Margin="0,0,0,10">
                <StackPanel Margin="10">
                    <TextBlock x:Name="txtMaKH" Text="Mã KH: " Margin="0,5"/>
                    <TextBlock x:Name="txtHoTen" Text="Họ Tên: " Margin="0,5"/>
                    <TextBlock x:Name="txtSDT" Text="Số Điện Thoại: " Margin="0,5"/>
                    <TextBlock x:Name="txtEmail" Text="Email: " Margin="0,5"/>
                    <TextBlock x:Name="txtNgaySinh" Text="Ngày Sinh: " Margin="0,5"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Thông tin thanh toán">
                <StackPanel Margin="10">
                    <TextBlock x:Name="txtNgayLap" Text="Ngày Lập: " Margin="0,5"/>
                    <TextBlock x:Name="txtTienDV" Text="Tiền Dịch Vụ: " Margin="0,5" Foreground="#E67E22" FontWeight="Bold"/>
                    <TextBlock x:Name="txtTienSP" Text="Tiền Sản Phẩm: " Margin="0,5" Foreground="#2196F3" FontWeight="Bold"/>
                    <Separator Margin="0,5"/>
                    <TextBlock x:Name="txtTongTien" Text="Tổng Thanh Toán: " FontSize="18" Foreground="#2ECC71" FontWeight="Bold"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </Grid>
</Window>