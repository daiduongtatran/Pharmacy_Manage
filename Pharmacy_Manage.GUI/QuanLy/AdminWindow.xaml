<Window x:Class="Pharmacy_Manage.GUI.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Quản Trị Hệ Thống - Clinic Track" Height="768" Width="1366"
        WindowStartupLocation="CenterScreen" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <Style x:Key="SidebarBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0AEC0"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#F7FAFC" CornerRadius="25" BorderBrush="#E2E8F0" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1E293B" CornerRadius="25,0,0,25">
                <Grid>
                    <StackPanel Margin="0,50,0,0">

                        <TextBlock FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,50">
                            <Run Text="Clinic" Foreground="White" />
                            <Run Text="Admin" Foreground="#4FD1C5" />
                        </TextBlock>

                        <Button x:Name="btnMenu0" Style="{StaticResource SidebarBtnStyle}" Tag="0" Click="Menu_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" FontSize="18" Margin="0,0,15,0"/>
                                <TextBlock Text="Trang chủ"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnMenu1" Style="{StaticResource SidebarBtnStyle}" Tag="1" Click="Menu_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💊" FontSize="18" Margin="0,0,15,0"/>
                                <TextBlock Text="Kho thuốc"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnMenu2" Style="{StaticResource SidebarBtnStyle}" Tag="2" Click="Menu_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🧾" FontSize="18" Margin="0,0,15,0"/>
                                <TextBlock Text="Hóa đơn"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnMenu3" Style="{StaticResource SidebarBtnStyle}" Tag="3" Click="Menu_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👥" FontSize="18" Margin="0,0,15,0"/>
                                <TextBlock Text="Nhân viên "/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnMenu4" Style="{StaticResource SidebarBtnStyle}" Tag="4" Click="Menu_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📅" FontSize="18" Margin="0,0,15,0"/>
                                <TextBlock Text="Lịch hẹn"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Button Style="{StaticResource SidebarBtnStyle}" VerticalAlignment="Bottom" Margin="10,0,10,40" Click="Logout_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚪" FontSize="18" Margin="0,0,15,0"/>
                            <TextBlock Text="Đăng xuất" Foreground="#F87171"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="20,0,20,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">

                        <Border Background="White" CornerRadius="20" Height="45" Padding="5,0,20,0" Margin="0,0,20,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" Opacity="0.05" ShadowDepth="2"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="35" Height="35" Margin="5,0,10,0" Fill="#4FD1C5"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="txtAdminName" Text="Đang tải..." FontWeight="Bold" Foreground="#2D3748"/>
                                    <TextBlock Text="Quản Trị Viên" FontSize="12" Foreground="#718096"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>

                <ContentControl x:Name="MainContentArea" Grid.Row="1" Margin="20,0,20,20" />

            </Grid>
        </Grid>
    </Border>
</Window>