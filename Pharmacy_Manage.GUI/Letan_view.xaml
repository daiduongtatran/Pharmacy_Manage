<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Pharmacy_Manage.GUI" x:Class="Pharmacy_Manage.GUI.Letan_view"
             mc:Ignorable="d"
             MinHeight="400"
             d:DesignHeight="700"
             d:DesignWidth="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar: three buttons (In số thứ tự, Khám bệnh đặt trước, Bệnh nhân tái khám) -->
        <Border
            Grid.Row="0"
            BorderThickness="1"
            Height="108"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Margin="12"
                    Height="64"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Stretch"
                    Content="In số thứ tự"/>

                <Button
                    Grid.Column="1"
                    Margin="12"
                    Height="64"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Stretch"
                    Content="Khám bệnh đặt trước"/>

                <Button
                    Grid.Column="2"
                    Margin="12"
                    Height="64"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Stretch"
                    Content="Bệnh nhân tái khám"/>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            BorderThickness="1"
            Padding="8">
            <Grid Margin="1,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="157"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- Left: Queue box -->
                <StackPanel Grid.Column="0" Margin="8,8,8,0" VerticalAlignment="Top" Height="110">
                    <TextBlock Text="Hàng đợi"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,8"/>
                    <Border Background="#FFF5F5F5"
                            BorderBrush="Gray"
                            BorderThickness="1"
                            CornerRadius="6"
                            Height="82"
                            HorizontalAlignment="Stretch" Width="116">
                        <TextBlock x:Name="QueueNumberText"
                                   Text="001"
                                   FontSize="48"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <Grid Grid.Column="1" Margin="12,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Thông tin bệnh nhân"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="4"/>

                    <!-- Form -->
                    <Grid Grid.Row="1" Margin="8" >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Mã bệnh nhân -->
                            <RowDefinition Height="Auto"/> <!-- Tên -->
                            <RowDefinition Height="Auto"/> <!-- Tuổi -->
                            <RowDefinition Height="Auto"/> <!-- Giới tính -->
                            <RowDefinition Height="Auto"/> <!-- Ngày sinh -->
                            <RowDefinition Height="*"/>    <!-- Triệu chứng -->
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Mã bệnh nhân:" VerticalAlignment="Center" Margin="4"/>
                        <TextBox x:Name="txtPatientId" Grid.Row="0" Grid.Column="1" Margin="4" Height="28"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Tên:" VerticalAlignment="Center" Margin="4"/>
                        <TextBox x:Name="txtName" Grid.Row="1" Grid.Column="1" Margin="4" Height="28"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Tuổi:" VerticalAlignment="Center" Margin="4"/>
                        <TextBox x:Name="txtAge" Grid.Row="2" Grid.Column="1" Margin="4" Height="28"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Giới tính:" VerticalAlignment="Center" Margin="4"/>
                        <ComboBox x:Name="cbGender" Grid.Row="3" Grid.Column="1" Margin="4" Height="28">
                            <ComboBoxItem Content="Nam"/>
                            <ComboBoxItem Content="Nữ"/>
                            <ComboBoxItem Content="Khác"/>
                        </ComboBox>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Ngày sinh:" VerticalAlignment="Center" Margin="4"/>
                        <DatePicker x:Name="dpDOB" Grid.Row="4" Grid.Column="1" Margin="4" Height="28"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Triệu chứng:" VerticalAlignment="Top" Margin="4"/>
                        <TextBox x:Name="txtSymptoms" Grid.Row="5" Grid.Column="1" Margin="4" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="80"/>
                    </Grid>

                    <!-- Action buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="4">
                        <Button x:Name="btnSent_Inf" Content="Gửi thông tin" Width="90" Margin="4" Click="BtnSent_Inf_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
